# Grafana Cloud — Claude Code Tracing
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Find all three values at:
#   grafana.com → My Account → your stack → Configure (under OpenTelemetry)

# =============================================================================
# OTLP Gateway (where traces are sent)
# =============================================================================
# The endpoint URL and instance ID are shown on the OpenTelemetry config page.
GRAFANA_OTLP_GATEWAY_URL=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_OTLP_INSTANCE_ID=000000

# =============================================================================
# Cloud API Token
# =============================================================================
# Click "Generate now" on the same OpenTelemetry page to create a token.
GRAFANA_CLOUD_TOKEN=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Trace mode (leave as "direct")
# =============================================================================
TRACE_MODE=direct
