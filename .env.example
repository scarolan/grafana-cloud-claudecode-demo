# Grafana Cloud Credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate a single Cloud Access Token at:
#   grafana.com → My Account → Access Policies → Generate token
# This one token grants write access to metrics, logs, traces, and OTLP.

# =============================================================================
# Grafana Cloud Token (one token for all signals)
# =============================================================================
GRAFANA_CLOUD_TOKEN=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Grafana Cloud — Metrics (Prometheus remote write)
# =============================================================================
# Find URL and username at: grafana.com → My Account → Prometheus → Details
GRAFANA_METRICS_URL=https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_METRICS_USERNAME=000000

# =============================================================================
# Grafana Cloud — Logs (Loki)
# =============================================================================
# Find URL and username at: grafana.com → My Account → Loki → Details
GRAFANA_LOGS_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_LOGS_USERNAME=000000

# =============================================================================
# Grafana Cloud — Traces (Tempo)
# =============================================================================
# Find URL and username at: grafana.com → My Account → Tempo → Details
GRAFANA_TRACES_URL=https://tempo-prod-XX-prod-us-east-0.grafana.net:443
GRAFANA_TRACES_USERNAME=000000

# =============================================================================
# Demo-specific variables (add your own below)
# =============================================================================
# DEMO_APP_PORT=8080
# DEMO_DB_PASSWORD=changeme
