{
  "hooks": {
    "tool-start": {
      "command": "python trace_hook.py --hook tool-start",
      "description": "Start OpenTelemetry trace span for tool execution"
    },
    "tool-end": {
      "command": "python trace_hook.py --hook tool-end",
      "description": "End OpenTelemetry trace span for tool execution"
    }
  },
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(docker compose *)",
      "Bash(terraform *)",
      "Bash(chmod +x *)",
      "Bash(./scripts/*)",
      "Bash(bats *)",
      "Bash(k6 *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(git -C:*)",
      "Bash(git commit:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(python *)",
      "Bash(pip *)"
    ]
  }
}