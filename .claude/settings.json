{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/trace_hook.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/trace_hook.py",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/trace_hook.py",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(docker compose *)",
      "Bash(terraform *)",
      "Bash(chmod +x *)",
      "Bash(./scripts/*)",
      "Bash(bats *)",
      "Bash(k6 *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(git -C:*)",
      "Bash(git commit:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(python *)",
      "Bash(pip *)"
    ]
  }
}
