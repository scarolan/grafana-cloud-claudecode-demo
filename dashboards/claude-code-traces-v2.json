      "gridPos": { "x": 0, "y": 8, "w": 14, "h": 9 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
