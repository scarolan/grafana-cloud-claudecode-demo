        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "transformations": [{
        "id": "renameByRegex",
        "options": {
          "regex": ".*span\\.tool\\.name=\"([^\"]+)\".*",
          "renamePattern": "$1"
