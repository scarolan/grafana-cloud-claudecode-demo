{
  "description": "Claude Code OpenTelemetry tracing dashboard - visualizes tool usage, performance, and session flows",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": {
        "type": "grafana",
        "uid": "-- Grafana --"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "code": {
          "language": "html",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "<div style='padding: 16px; background: linear-gradient(135deg, #7C3AED 0%, #3B82F6 100%); color: white; border-radius: 6px; display: flex; align-items: center; justify-content: space-between;'>\n  <div>\n    <h1 style='margin: 0 0 8px 0; font-size: 24px; font-weight: 600;'>&#129302; Claude Code Tracing Dashboard</h1>\n    <p style='margin: 0; font-size: 14px; opacity: 0.9;'>Real-time observability for AI-powered development workflows</p>\n  </div>\n  <div style='display: flex; align-items: center; gap: 12px;'>\n    <div style='text-align: right; font-size: 12px; opacity: 0.8;'>\n      <div>OpenTelemetry</div>\n      <div>Distributed Tracing</div>\n    </div>\n    <div style='width: 3px; height: 40px; background: rgba(255,255,255,0.3); border-radius: 2px;'></div>\n    <div style='font-size: 36px;'>&#9889;</div>\n  </div>\n</div>",
        "mode": "html"
      },
      "pluginVersion": "9.0.0",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 1,
      "panels": [],
      "title": "Claude Code Session Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Total number of Claude Code tool calls over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | rate() by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Tool Calls Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Total tool calls by type",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "vis": false } },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | count_over_time() by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Tool Call Count",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 4,
      "panels": [],
      "title": "Tool Usage Patterns",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Distribution of tool usage by type",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "vis": false } },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | count_over_time() by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Tool Usage Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Average execution time by tool type",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 100,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }]
          },
          "unit": "ns"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | avg_over_time(span:duration) by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Average Tool Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 7,
      "panels": [],
      "title": "Performance & Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "P95 tool execution times",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "ns"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | quantile_over_time(span:duration, .95) by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "P95 Tool Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Tool execution error rate",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\" && span:status=error} | rate()",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Tool",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 10,
      "panels": [],
      "title": "Session Deep Dive",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Recent Claude Code traces - click to explore",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 11,
      "options": {},
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"}",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent Traces",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 12,
      "panels": [],
      "title": "Tool Payload & Execution Details",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Average size of tool input payloads by tool type - proxy for request complexity",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 13,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | avg_over_time(span.tool.input_size) by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Avg Input Size by Tool",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Average size of tool response payloads by tool type - indicates output volume",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 14,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\"} | avg_over_time(span.tool.response_size) by(span.tool.name)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Avg Response Size by Tool",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Most frequently accessed files across Claude Code sessions",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "vis": false } },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "id": 15,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\" && span.tool.file_path!=\"\"} | count_over_time() by(span.tool.file_path)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "File Access Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "What Claude Code is doing - descriptions from Bash and Agent tool calls",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "vis": false } },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "id": 16,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "query": "{resource.service.name=\"claude-code\" && span.tool.description!=\"\"} | count_over_time() by(span.tool.description)",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "title": "Tool Descriptions (What Claude Is Doing)",
      "type": "piechart"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "claude-code",
    "tracing",
    "opentelemetry",
    "workshop"
